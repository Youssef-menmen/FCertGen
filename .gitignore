# ═══════════════════════════════════════════════
#  .gitignore — React Frontend
#  NE PAS COMMITER ces fichiers sur GitHub
# ═══════════════════════════════════════════════

# ── Dépendances ──────────────────────────────
node_modules/

# ── Build ────────────────────────────────────
build/
dist/

# ── Variables d'environnement sensibles ──────
.env.local
.env.production.local
.env.development.local
.env.test.local
# ⚠️ .env.development et .env.production sont
#    committés SANS valeurs sensibles (juste la clé)
#    Les vraies valeurs sont sur Netlify

# ── Cache ────────────────────────────────────
.cache/
.parcel-cache/

# ── IDE ──────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*

# ── OS ───────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Tests ────────────────────────────────────
coverage/
